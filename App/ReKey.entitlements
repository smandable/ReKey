<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Sandbox: on. -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- Outgoing network client: the only network capability. Used solely for
         the HIBP k-anonymity range query and on-demand change-password URL
         resolution. There is no network server entitlement. -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Access to files the user explicitly picks in the import panel, with
         write so the source CSV can be securely overwritten and deleted. -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Persist access to the folder the user picks for the opt-in auto-import
         watcher (e.g. Downloads), across launches, via a security-scoped
         bookmark. Only used when the user enables folder watching. -->
    <key>com.apple.security.files.bookmarks.app-scope</key>
    <true/>
</dict>
</plist>
